# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://dignity_user:your_strong_password@localhost:5432/dignity_store"

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"
NEXTAUTH_URL="https://yourdomain.com"

# ── Stripe (Credit Card Payments) ─────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Fawry (Egyptian Payment Gateway) ──────────────────────────
# Get credentials from: https://developer.fawrystaging.com/
FAWRY_MERCHANT_CODE="your_merchant_code"
FAWRY_SECURITY_KEY="your_security_key"
# Use "test" for staging, "production" for live
FAWRY_MODE="test"
FAWRY_BASE_URL="https://atfawry.fawrystaging.com"
# Change to production URL when live:
# FAWRY_BASE_URL="https://www.atfawry.com"

# ── Cloudinary (Image Storage) ────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Email (for order confirmations) ──────────────────────────
# Using SendGrid or any SMTP provider
EMAIL_SERVER_HOST="smtp.sendgrid.net"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="apikey"
EMAIL_SERVER_PASSWORD="your_sendgrid_api_key"
EMAIL_FROM="noreply@dignitystore.com"

# ── App Config ─────────────────────────────────────────────────
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
